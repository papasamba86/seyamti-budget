# Base de données Neon (PostgreSQL)
# Obtenez votre URL depuis https://console.neon.tech
DATABASE_URL=postgres://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# NextAuth - générez un secret avec: openssl rand -base64 32
NEXTAUTH_SECRET=votre_secret_tres_long_et_aleatoire
NEXTAUTH_URL=http://localhost:3000

# En production sur Vercel, NEXTAUTH_URL est automatiquement défini
